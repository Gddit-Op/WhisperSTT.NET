<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WhisperSTT.App.ViewModels"
        x:Class="WhisperSTT.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="WhisperSTT"
        Width="1140"
        Height="780"
        MinWidth="920"
        MinHeight="660"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="20"
        RowDefinitions="Auto,*"
        RowSpacing="18">
    <Border Classes="header-shell">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="20">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="18">
          <Border Width="58"
                  Height="58"
                  Background="{StaticResource AccentSoftBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="18">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}"
                       Text="W" />
          </Border>

          <StackPanel Grid.Column="1"
                      VerticalAlignment="Center"
                      Spacing="8">
            <StackPanel Orientation="Horizontal"
                        Spacing="12">
              <TextBlock Classes="page-title"
                         VerticalAlignment="Center"
                         Text="WhisperSTT" />
              <Border Classes="status-badge"
                      VerticalAlignment="Center"
                      Background="{Binding StatusBrush}">
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="{Binding StatusText}" />
              </Border>
            </StackPanel>
            <TextBlock Classes="page-subtitle"
                       Text="Desktop capture with server-side Whisper transcription over HTTP."
                       TextWrapping="Wrap" />
          </StackPanel>
        </Grid>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
          <Button Classes="secondary"
                  Width="132"
                  Command="{Binding CancelRecordingCommand}"
                  Content="Cancel" />
          <Button Classes="primary"
                  Width="172"
                  Command="{Binding ToggleRecordingCommand}"
                  Content="{Binding RecordingButtonText}" />
        </StackPanel>
      </Grid>
    </Border>

    <TabControl Grid.Row="1"
                Classes="main-tabs">
      <TabItem Header="Dashboard">
        <ScrollViewer x:Name="DashboardScrollViewer"
                      Margin="0,18,0,0"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <Grid Width="{Binding #DashboardScrollViewer.Bounds.Width}"
                RowDefinitions="Auto,Auto,Auto"
                RowSpacing="10">
            <Grid ColumnDefinitions="1.15*,0.85*"
                  ColumnSpacing="18">
              <Border Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="14">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title"
                               Text="Capture Overview" />
                    <TextBlock Classes="section-caption"
                               Text="Current transcription target, runtime mode and model availability." />
                  </StackPanel>
                  <TextBlock Grid.Row="1"
                             Classes="kv-value"
                             Text="{Binding TranscriptionModeSummary}"
                             TextWrapping="Wrap" />
                  <Border Grid.Row="2"
                          Classes="card-muted">
                    <Grid ColumnDefinitions="150,*"
                          ColumnSpacing="14">
                      <TextBlock Classes="kv-label"
                                 Text="Model Status" />
                      <TextBlock Grid.Column="1"
                                 Classes="kv-value"
                                 Text="{Binding ActiveModelSummary}"
                                 TextWrapping="Wrap" />
                    </Grid>
                  </Border>
                </Grid>
              </Border>

              <Border Grid.Column="1"
                      Classes="card">
                <Grid RowDefinitions="Auto,Auto"
                      RowSpacing="14">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title"
                               Text="Quick Reference" />
                    <TextBlock Classes="section-caption"
                               Text="Hotkeys and current capture context at a glance." />
                  </StackPanel>
                  <Grid Grid.Row="1"
                        ColumnDefinitions="*,*"
                        RowDefinitions="Auto,Auto"
                        ColumnSpacing="14"
                        RowSpacing="14">
                    <Border Classes="card-muted">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="metric-label"
                                   Text="Toggle Hotkey" />
                        <TextBlock Classes="metric-value"
                                   Text="{Binding Settings.Hotkeys.ToggleRecordingGesture}" />
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Classes="card-muted">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="metric-label"
                                   Text="Cancel Hotkey" />
                        <TextBlock Classes="metric-value"
                                   Text="{Binding Settings.Hotkeys.CancelRecordingGesture}" />
                      </StackPanel>
                    </Border>
                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Classes="card-muted">
                      <Grid ColumnDefinitions="110,*"
                            ColumnSpacing="14">
                        <TextBlock Classes="kv-label"
                                   Text="Detected Language" />
                        <TextBlock Grid.Column="1"
                                   Classes="kv-value"
                                   Text="{Binding LastDetectedLanguage}" />
                      </Grid>
                    </Border>
                  </Grid>
                </Grid>
              </Border>
            </Grid>

            <Border Grid.Row="1"
                    Classes="card">
              <Grid RowDefinitions="Auto,*"
                    RowSpacing="14">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="14">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title"
                               Text="Latest Transcript" />
                    <TextBlock Classes="section-caption"
                               Text="The most recent microphone transcription, ready to copy or paste." />
                  </StackPanel>
                  <Border Grid.Column="1"
                          Classes="toolbar-pill"
                          VerticalAlignment="Top">
                    <Button Classes="secondary"
                            MinWidth="82"
                            Padding="10,8"
                            Command="{Binding CopyLatestTranscriptCommand}">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="3">
                        <Canvas Width="16"
                                Height="16">
                          <Border Width="9"
                                  Height="9"
                                  Canvas.Left="1"
                                  Canvas.Top="4"
                                  Background="Transparent"
                                  BorderBrush="{StaticResource TextSecondaryBrush}"
                                  BorderThickness="1.5"
                                  CornerRadius="2" />
                          <Border Width="9"
                                  Height="9"
                                  Canvas.Left="5"
                                  Canvas.Top="1"
                                  Background="Transparent"
                                  BorderBrush="{StaticResource TextBrush}"
                                  BorderThickness="1.5"
                                  CornerRadius="2" />
                        </Canvas>
                        <TextBlock VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Copy" />
                      </StackPanel>
                    </Button>
                  </Border>
                </Grid>
                <TextBox Grid.Row="1"
                         Classes="transcript-box"
                         Height="220"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Text="{Binding CurrentTranscript, Mode=OneWay}"
                         TextWrapping="Wrap" />
              </Grid>
            </Border>

            <Border Grid.Row="2"
                    Classes="card">
              <Expander Classes="diagnostic-expander"
                        HorizontalAlignment="Stretch"
                        IsExpanded="False">
                <Expander.Header>
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="12">
                    <TextBlock Classes="section-title"
                               Text="Diagnostics" />
                    <TextBlock Grid.Column="1"
                               Classes="section-caption"
                               VerticalAlignment="Center"
                               Text="Show details" />
                  </Grid>
                </Expander.Header>

                <ScrollViewer x:Name="DiagnosticsScrollViewer"
                              Margin="0,14,0,0"
                              MaxHeight="190"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                  <Grid Width="{Binding #DiagnosticsScrollViewer.Bounds.Width}"
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="16"
                        RowSpacing="8">
                    <TextBlock Classes="kv-label"
                               MinWidth="124"
                               Text="Current Status" />
                    <TextBlock Grid.Column="1"
                               Classes="kv-value"
                               Text="{Binding StatusText}"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1"
                               Classes="kv-label"
                               Text="Detected Language" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Classes="kv-value"
                               Text="{Binding DetectedLanguageText}"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2"
                               Classes="kv-label"
                               Text="Last Message" />
                    <Border Grid.Row="2"
                            Grid.Column="1"
                            Classes="card-muted"
                            Padding="12">
                      <TextBlock Classes="kv-value"
                                 Text="{Binding LastError}"
                                 TextWrapping="Wrap" />
                    </Border>
                    <TextBlock Grid.Row="3"
                               Classes="kv-label"
                               Text="Storage Paths" />
                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             Classes="path-box"
                             MinHeight="72"
                             IsReadOnly="True"
                             Text="{Binding PersistenceSummary, Mode=OneWay}" />
                  </Grid>
                </ScrollViewer>
              </Expander>
            </Border>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="File Transcription">
        <ScrollViewer Margin="0,18,0,0"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <Grid RowDefinitions="Auto,Auto,*"
                RowSpacing="18">
            <Border Classes="card">
              <Grid RowDefinitions="Auto,Auto"
                    RowSpacing="14">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-title"
                             Text="Source File" />
                  <TextBlock Classes="section-caption"
                             Text="Select a local .wav or .mp3 file for preview and transcription." />
                </StackPanel>
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="12">
                  <TextBox VerticalContentAlignment="Center"
                           Text="{Binding SelectedFilePath, Mode=TwoWay}" />
                  <Button Grid.Column="1"
                          Classes="secondary"
                          Width="112"
                          Command="{Binding BrowseFileCommand}"
                          Content="Browse" />
                  <Button Grid.Column="2"
                          Classes="primary"
                          Width="152"
                          Command="{Binding TranscribeFileCommand}"
                          Content="Transcribe File" />
                </Grid>
              </Grid>
            </Border>

            <Grid Grid.Row="1"
                  ColumnDefinitions="1.1*,0.9*"
                  ColumnSpacing="18">
              <Border Classes="drop-zone"
                      DragDrop.AllowDrop="True"
                      DragDrop.DragOver="OnAudioFileDragOver"
                      DragDrop.Drop="OnAudioFileDrop">
                <Grid RowDefinitions="Auto,Auto"
                      RowSpacing="10">
                  <TextBlock HorizontalAlignment="Center"
                             Classes="section-title"
                             Text="Drop Audio File Here" />
                  <TextBlock Grid.Row="1"
                             HorizontalAlignment="Center"
                             Classes="section-caption"
                             Text="Drag a .wav or .mp3 file into this area to load it without leaving the workflow."
                             TextAlignment="Center"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>

              <Border Grid.Column="1"
                      Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="14">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title"
                               Text="Playback" />
                    <TextBlock Classes="section-caption"
                               Text="Quick control of the selected source file before transcription." />
                  </StackPanel>
                  <Grid Grid.Row="1"
                        ColumnDefinitions="*,*,*"
                        ColumnSpacing="10">
                    <Button Classes="secondary"
                            Command="{Binding PlayPreviewCommand}"
                            Content="Play" />
                    <Button Grid.Column="1"
                            Classes="secondary"
                            Command="{Binding PausePreviewCommand}"
                            Content="Pause" />
                    <Button Grid.Column="2"
                            Classes="secondary"
                            Command="{Binding StopPreviewCommand}"
                            Content="Stop" />
                  </Grid>
                  <Border Grid.Row="2"
                          Classes="card-muted">
                    <Grid ColumnDefinitions="120,*"
                          ColumnSpacing="14">
                      <TextBlock Classes="kv-label"
                                 Text="Elapsed" />
                      <TextBlock Grid.Column="1"
                                 Classes="kv-value"
                                 Text="{Binding FileTranscriptionElapsedText}" />
                    </Grid>
                  </Border>
                </Grid>
              </Border>
            </Grid>

            <Border Grid.Row="2"
                    Classes="card">
              <Grid RowDefinitions="Auto,*"
                    RowSpacing="14">
                <StackPanel Spacing="4">
                  <TextBlock Classes="section-title"
                             Text="File Transcript" />
                  <TextBlock Classes="section-caption"
                             Text="Read-only transcript output for the selected audio file." />
                </StackPanel>
                <TextBox Grid.Row="1"
                         Classes="transcript-box"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Text="{Binding FileTranscript, Mode=OneWay}"
                         TextWrapping="Wrap" />
              </Grid>
            </Border>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Settings">
        <ScrollViewer Margin="0,18,0,0"
                      VerticalScrollBarVisibility="Auto">
          <Grid ColumnDefinitions="*,*"
                ColumnSpacing="18">
            <Grid RowDefinitions="Auto,Auto"
                  RowSpacing="18">
              <Border Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="16">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title"
                               Text="Transcription" />
                    <TextBlock Classes="section-caption"
                               Text="Execution target, language, runtime and model selection for microphone and file workflows." />
                  </StackPanel>
                  <Grid Grid.Row="1"
                        ColumnDefinitions="180,*"
                        ColumnSpacing="16"
                        RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                        RowSpacing="12">
                    <TextBlock Classes="form-label" Text="Execution Target" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding TranscriptionTargets}"
                              SelectedItem="{Binding SelectedTranscriptionTarget}" />
                    <TextBlock Grid.Row="1" Classes="form-label" Text="Language Mode" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="1"
                              ItemsSource="{Binding Languages}"
                              SelectedItem="{Binding Settings.Transcription.LanguageMode}" />
                    <TextBlock Grid.Row="2" Classes="form-label" Text="Runtime" />
                    <ComboBox Grid.Row="2"
                              Grid.Column="1"
                              ItemsSource="{Binding RuntimePreferences}"
                              SelectedItem="{Binding Settings.Transcription.RuntimePreference}" />
                    <TextBlock Grid.Row="3" Classes="form-label" Text="Recording Model" />
                    <ComboBox Grid.Row="3"
                              Grid.Column="1"
                              ItemsSource="{Binding ModelPresets}"
                              SelectedItem="{Binding Settings.Transcription.RecordingModelPreset}" />
                    <TextBlock Grid.Row="4" Classes="form-label" Text="File Model" />
                    <ComboBox Grid.Row="4"
                              Grid.Column="1"
                              ItemsSource="{Binding ModelPresets}"
                              SelectedItem="{Binding Settings.Transcription.FileModelPreset}" />
                    <TextBlock Grid.Row="5" Classes="form-label" Text="Microphone Threads" />
                    <TextBox Grid.Row="5"
                             Grid.Column="1"
                             Text="{Binding Settings.Transcription.RecordingThreadCount}" />
                    <TextBlock Grid.Row="6" Classes="form-label" Text="File Threads" />
                    <TextBox Grid.Row="6"
                             Grid.Column="1"
                             Text="{Binding Settings.Transcription.FileThreadCount}" />
                    <TextBlock Grid.Row="7" Classes="form-label" Text="Custom Model Path" />
                    <Grid Grid.Row="7"
                          Grid.Column="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                      <TextBox Text="{Binding CustomModelPath}" />
                      <Button Grid.Column="1"
                              Classes="secondary"
                              Width="108"
                              Command="{Binding BrowseModelFileCommand}"
                              Content="Browse" />
                    </Grid>
                    <TextBlock Grid.Row="8" Classes="form-label" Text="OpenVINO Toolkit" />
                    <Grid Grid.Row="8"
                          Grid.Column="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                      <TextBox Text="{Binding OpenVinoRuntimePath}" />
                      <Button Grid.Column="1"
                              Classes="secondary"
                              Width="108"
                              Command="{Binding BrowseOpenVinoRuntimePathCommand}"
                              Content="Browse" />
                    </Grid>
                  </Grid>
                  <StackPanel Grid.Row="2"
                              Spacing="8">
                    <TextBlock Classes="section-caption"
                               Text="Select the folder that contains the OpenVINO runtime binaries. When set, it is added to the process PATH before OpenVINO is initialized."
                               TextWrapping="Wrap" />
                    <TextBlock Classes="section-caption"
                               Text="When Execution Target is Server, the desktop app uploads audio to the server over HTTP. The server performs transcription with its own Whisper model, runtime, language mode, and thread counts from appsettings.json."
                               TextWrapping="Wrap" />
                    <TextBlock Classes="section-caption"
                               Text="Whisper.net uses local ggml model files. If Custom Model Path points to a local file, it takes priority over preset mapping. Runtime Auto prefers CUDA, then Vulkan, then OpenVino, then CPU."
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Grid>
              </Border>

              <Border Grid.Row="1"
                      Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="16">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title"
                               Text="Hotkeys" />
                    <TextBlock Classes="section-caption"
                               Text="Press-to-capture fields for start/stop and cancel shortcuts." />
                  </StackPanel>
                  <Grid Grid.Row="1"
                        ColumnDefinitions="180,*"
                        ColumnSpacing="16"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="12">
                    <TextBlock Classes="form-label" Text="Start / Stop Recording" />
                    <TextBox Grid.Column="1"
                             IsReadOnly="True"
                             KeyDown="OnHotkeyTextBoxKeyDown"
                             Tag="ToggleRecording"
                             Text="{Binding Settings.Hotkeys.ToggleRecordingGesture}" />
                    <TextBlock Grid.Row="1" Classes="form-label" Text="Cancel Recording" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             IsReadOnly="True"
                             KeyDown="OnHotkeyTextBoxKeyDown"
                             Tag="CancelRecording"
                             Text="{Binding Settings.Hotkeys.CancelRecordingGesture}" />
                  </Grid>
                  <TextBlock Grid.Row="2"
                             Classes="section-caption"
                             Text="Click a field and press the desired shortcut. Modifier-only shortcuts are ignored. Save settings to persist and reapply the new hotkeys."
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </Grid>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="18">
              <Border Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="16">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title"
                               Text="Audio + Paste" />
                    <TextBlock Classes="section-caption"
                               Text="Input device selection and clipboard/paste behavior." />
                  </StackPanel>
                  <Grid Grid.Row="1"
                        ColumnDefinitions="180,*"
                        ColumnSpacing="16">
                    <TextBlock Classes="form-label" Text="Recording Input Device" />
                    <Grid Grid.Column="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                      <ComboBox ItemsSource="{Binding InputDevices}"
                                SelectedItem="{Binding SelectedInputDevice}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <Button Grid.Column="1"
                              Classes="secondary"
                              Width="108"
                              Command="{Binding RefreshInputDevicesCommand}"
                              Content="Refresh" />
                    </Grid>
                  </Grid>
                  <StackPanel Grid.Row="2"
                              Spacing="10">
                    <CheckBox Classes="setting-check"
                              Content="Enable feedback sounds"
                              IsChecked="{Binding Settings.Audio.EnableFeedbackSounds}" />
                    <CheckBox Classes="setting-check"
                              Content="Enable near-realtime live preview placeholder"
                              IsChecked="{Binding Settings.Audio.EnableLivePreview}" />
                    <CheckBox Classes="setting-check"
                              Content="Transcribe microphone directly from memory (no temp WAV)"
                              IsChecked="{Binding Settings.Audio.TranscribeMicrophoneDirectlyFromMemory}" />
                    <CheckBox Classes="setting-check"
                              Content="Restore clipboard after paste"
                              IsChecked="{Binding Settings.Paste.RestoreClipboardAfterPaste}" />
                  </StackPanel>
                </Grid>
              </Border>

              <Border Grid.Row="1"
                      Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="16">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title"
                               Text="Logging + Connectivity" />
                    <TextBlock Classes="section-caption"
                               Text="Logging switches, remote endpoint details and readable storage locations." />
                  </StackPanel>
                  <CheckBox Grid.Row="1"
                            Classes="setting-check"
                            Content="Enable activity log"
                            IsChecked="{Binding Settings.Logging.EnableLogging}" />
                  <CheckBox Grid.Row="2"
                            Classes="setting-check"
                            Content="Write transcript history"
                            IsChecked="{Binding Settings.Logging.WriteTranscriptHistory}" />
                  <Grid Grid.Row="3"
                        ColumnDefinitions="180,*"
                        ColumnSpacing="16"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="12">
                    <TextBlock Classes="form-label" Text="Remote Server URL" />
                    <TextBox Grid.Column="1"
                             Text="{Binding RemoteServerUrl}" />
                    <TextBlock Grid.Row="1"
                               Classes="form-label"
                               Text="Remote Timeout (seconds)" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding RemoteTimeoutSeconds}" />
                  </Grid>
                  <Grid Grid.Row="4"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="10">
                    <TextBlock Classes="kv-label"
                               Text="Storage Paths" />
                    <TextBox Grid.Row="1"
                             Classes="path-box"
                             IsReadOnly="True"
                             Text="{Binding PersistenceSummary}" />
                  </Grid>
                </Grid>
              </Border>

              <Border Grid.Row="2"
                      Classes="card">
                <Grid RowDefinitions="Auto,Auto"
                      RowSpacing="16">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="section-title"
                               Text="Model Tools" />
                    <TextBlock Classes="section-caption"
                               Text="Maintenance actions for models, temp files and persisted settings." />
                  </StackPanel>
                  <StackPanel Grid.Row="1"
                              Spacing="10">
                    <Button Classes="primary"
                            Command="{Binding DownloadModelCommand}"
                            Content="Download Selected Model" />
                    <Button Classes="secondary"
                            Command="{Binding DeleteTempAudioFilesCommand}"
                            Content="Delete Temp WAV Files" />
                    <Button Classes="secondary"
                            Command="{Binding SaveSettingsCommand}"
                            Content="Save Settings" />
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
