<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Bahnschrift" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource BodyFontSize}" />
  </Style>

  <Style Selector="TextBlock.page-title">
    <Setter Property="FontSize" Value="{DynamicResource PageTitleFontSize}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <Style Selector="TextBlock.page-subtitle">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="TextBlock.overlay-title">
    <Setter Property="FontSize" Value="26" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <Style Selector="TextBlock.overlay-subtitle">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="{DynamicResource SectionTitleFontSize}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.section-caption">
    <Setter Property="FontSize" Value="{DynamicResource CaptionFontSize}" />
    <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
  </Style>

  <Style Selector="TextBlock.metric-label">
    <Setter Property="FontSize" Value="{DynamicResource CaptionFontSize}" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.metric-value">
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="TextBlock.kv-label">
    <Setter Property="FontSize" Value="{DynamicResource CaptionFontSize}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="TextBlock.kv-value">
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <Style Selector="TextBlock.form-label">
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FontSize" Value="{DynamicResource CaptionFontSize}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Padding" Value="20" />
  </Style>

  <Style Selector="Border.card-muted">
    <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="Border.header-shell">
    <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="22" />
    <Setter Property="Padding" Value="18" />
  </Style>

  <Style Selector="Border.status-badge">
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="12,6" />
  </Style>

  <Style Selector="Border.drop-zone">
    <Setter Property="Background" Value="{DynamicResource AccentSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="20" />
    <Setter Property="Padding" Value="26" />
  </Style>

  <Style Selector="Border.toolbar-pill">
    <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="8" />
  </Style>

  <Style Selector="Border.recording-overlay-scrim">
    <Setter Property="Background" Value="{DynamicResource OverlayScrimBrush}" />
  </Style>

  <Style Selector="Border.recording-overlay-card">
    <Setter Property="Background" Value="{DynamicResource OverlayCardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="32" />
    <Setter Property="Padding" Value="28" />
    <Setter Property="MaxWidth" Value="760" />
  </Style>

  <Style Selector="Border.waveform-pill">
    <Setter Property="Background" Value="{DynamicResource WaveformPillBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="22,18" />
  </Style>

  <Style Selector="Button">
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="16,10" />
    <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource FieldHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
  </Style>

  <Style Selector="Button:disabled">
    <Setter Property="Opacity" Value="0.55" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
  </Style>

  <Style Selector="Button.primary:pressed">
    <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentPressedBrush}" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <Style Selector="Button.overlay-recording">
    <Setter Property="MinHeight" Value="50" />
    <Setter Property="MinWidth" Value="178" />
    <Setter Property="Padding" Value="22,12" />
    <Setter Property="Background" Value="{DynamicResource OverlayActionBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource OverlayActionBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="CornerRadius" Value="999" />
  </Style>

  <Style Selector="Button.overlay-recording:pointerover">
    <Setter Property="Background" Value="{DynamicResource OverlayActionHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource OverlayActionHoverBrush}" />
  </Style>

  <Style Selector="Button.overlay-recording:pressed">
    <Setter Property="Background" Value="{DynamicResource OverlayActionPressedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource OverlayActionPressedBrush}" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="MinHeight" Value="42" />
  </Style>

  <Style Selector="TextBox:pointerover">
    <Setter Property="Background" Value="{DynamicResource FieldHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
  </Style>

  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="TextBox.transcript-box">
    <Setter Property="Background" Value="{DynamicResource TranscriptBrush}" />
    <Setter Property="MinHeight" Value="280" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="TextBox.path-box">
    <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="AcceptsReturn" Value="True" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="MinHeight" Value="92" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="MinHeight" Value="42" />
  </Style>

  <Style Selector="ComboBox:pointerover">
    <Setter Property="Background" Value="{DynamicResource FieldHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
  </Style>

  <Style Selector="ComboBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="Margin" Value="0" />
  </Style>

  <Style Selector="CheckBox.setting-check">
    <Setter Property="MinHeight" Value="30" />
  </Style>

  <Style Selector="TabControl.main-tabs">
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="TabControl.main-tabs TabItem">
    <Setter Property="Padding" Value="16,10" />
    <Setter Property="Margin" Value="0,0,10,0" />
    <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TabControl.main-tabs TabItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource FieldHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
  </Style>

  <Style Selector="TabControl.main-tabs TabItem:selected">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
  </Style>

  <Style Selector="Expander.diagnostic-expander">
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Expander.diagnostic-expander /template/ ToggleButton#PART_ExpanderHeader">
    <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="14,12" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
</Styles>
