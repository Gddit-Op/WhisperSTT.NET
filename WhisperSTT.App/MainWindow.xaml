<Window x:Class="WhisperSTT.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:WhisperSTT.Core.Models;assembly=WhisperSTT.Core"
        mc:Ignorable="d"
        Title="WhisperSTT"
        Width="1100"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Bahnschrift"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="18"
                CornerRadius="18"
                Background="{StaticResource PanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Text="WhisperSTT" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{StaticResource TextBrush}"
                               Opacity="0.75"
                               Text="Offline desktop speech-to-text for system-wide dictation and local file transcription." />
                    <Border Margin="0,14,0,0"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            Background="{Binding StatusBrush}"
                            CornerRadius="999">
                        <TextBlock Foreground="White"
                                   FontWeight="SemiBold"
                                   Text="{Binding StatusText}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Width="150"
                            Margin="0,0,10,0"
                            Padding="14,10"
                            Background="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            Command="{Binding ToggleRecordingCommand}"
                            Content="{Binding RecordingButtonText}"
                            Foreground="White" />
                    <Button Width="130"
                            Padding="14,10"
                            Command="{Binding CancelRecordingCommand}"
                            Content="Cancel"
                            Foreground="{StaticResource TextBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="0,16,0,0"
                    Background="Transparent"
                    BorderThickness="0">
            <TabItem Header="Dashboard">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <UniformGrid Columns="3" Margin="0,0,0,16">
                        <Border Margin="0,0,12,0"
                                Padding="16"
                                Background="{StaticResource PanelBrush}"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Toggle Hotkey" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="22"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding Settings.Hotkeys.ToggleRecordingGesture}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0"
                                Padding="16"
                                Background="{StaticResource PanelBrush}"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Cancel Hotkey" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="22"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding Settings.Hotkeys.CancelRecordingGesture}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="16"
                                Background="{StaticResource PanelBrush}"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Model Status" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding ActiveModelSummary}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Grid.Row="1"
                            Padding="16"
                            Background="{StaticResource PanelBrush}"
                            CornerRadius="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Latest Transcript" />
                            <TextBox Grid.Row="1"
                                     Margin="0,12,0,0"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Disabled"
                                     IsReadOnly="True"
                                     Text="{Binding CurrentTranscript, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="0,16,0,0"
                            Padding="16"
                            Background="{StaticResource PanelBrush}"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Diagnostics" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding LastError}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{StaticResource TextBrush}"
                                       Opacity="0.7"
                                       Text="{Binding PersistenceSummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="File Transcription">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="16"
                            Background="{StaticResource PanelBrush}"
                            CornerRadius="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Margin="0,0,12,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding SelectedFilePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Width="110"
                                    Margin="0,0,12,0"
                                    Command="{Binding BrowseFileCommand}"
                                    Content="Browse" />
                            <Button Grid.Column="2"
                                    Width="140"
                                    Background="{StaticResource AccentBrush}"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    Command="{Binding TranscribeFileCommand}"
                                    Content="Transcribe File"
                                    Foreground="White" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Margin="0,16,0,16"
                                Orientation="Horizontal">
                        <Button Width="90"
                                Margin="0,0,12,0"
                                Command="{Binding PlayPreviewCommand}"
                                Content="Play" />
                        <Button Width="90"
                                Margin="0,0,12,0"
                                Command="{Binding PausePreviewCommand}"
                                Content="Pause" />
                        <Button Width="90"
                                Command="{Binding StopPreviewCommand}"
                                Content="Stop" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Padding="16"
                            Background="{StaticResource PanelBrush}"
                            CornerRadius="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="File Transcript" />
                            <TextBox Grid.Row="1"
                                     Margin="0,12,0,0"
                                     AcceptsReturn="True"
                                     HorizontalScrollBarVisibility="Disabled"
                                     IsReadOnly="True"
                                     Text="{Binding FileTranscript, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer Margin="0,16,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <Border Padding="16"
                                    Background="{StaticResource PanelBrush}"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Transcription" />
                                    <TextBlock Margin="0,16,0,4" Text="Language Mode" />
                                    <ComboBox ItemsSource="{Binding Languages}"
                                              SelectedItem="{Binding Settings.Transcription.LanguageMode}" />
                                    <TextBlock Margin="0,16,0,4" Text="Recording Model" />
                                    <ComboBox ItemsSource="{Binding ModelPresets}"
                                              SelectedItem="{Binding Settings.Transcription.RecordingModelPreset}" />
                                    <TextBlock Margin="0,16,0,4" Text="File Model" />
                                    <ComboBox ItemsSource="{Binding ModelPresets}"
                                              SelectedItem="{Binding Settings.Transcription.FileModelPreset}" />
                                    <TextBlock Margin="0,16,0,4" Text="Microphone Threads" />
                                    <TextBox Text="{Binding Settings.Transcription.RecordingThreadCount}" />
                                    <TextBlock Margin="0,16,0,4" Text="File Threads" />
                                    <TextBox Text="{Binding Settings.Transcription.FileThreadCount}" />
                                    <TextBlock Margin="0,16,0,4" Text="Custom Model ID" />
                                    <TextBox Text="{Binding Settings.Transcription.CustomModelId, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,16,0,4" Text="Custom Model Path" />
                                    <TextBox Text="{Binding Settings.Transcription.CustomModelPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Opacity="0.7"
                                               Text="Whisper.net uses local ggml model files. If Custom Model Path points to a local file, it takes priority over preset mapping."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    Background="{StaticResource PanelBrush}"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Hotkeys" />
                                    <TextBlock Margin="0,16,0,4" Text="Start / Stop Recording" />
                                    <TextBox IsReadOnly="True"
                                             PreviewKeyDown="OnHotkeyTextBoxPreviewKeyDown"
                                             Tag="ToggleRecording"
                                             Text="{Binding Settings.Hotkeys.ToggleRecordingGesture, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,16,0,4" Text="Cancel Recording" />
                                    <TextBox IsReadOnly="True"
                                             PreviewKeyDown="OnHotkeyTextBoxPreviewKeyDown"
                                             Tag="CancelRecording"
                                             Text="{Binding Settings.Hotkeys.CancelRecordingGesture, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Opacity="0.7"
                                               Text="Click a field and press the desired shortcut. Modifier-only shortcuts are ignored. Save settings to persist and reapply the new hotkeys."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0">
                            <Border Padding="16"
                                    Background="{StaticResource PanelBrush}"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Audio + Paste" />
                                    <TextBlock Margin="0,16,0,4" Text="Preferred Input Device Number" />
                                    <TextBox Text="{Binding PreferredInputDeviceNumberText, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Margin="0,16,0,0"
                                              Content="Enable feedback sounds"
                                              IsChecked="{Binding Settings.Audio.EnableFeedbackSounds}" />
                                    <CheckBox Margin="0,8,0,0"
                                              Content="Enable near-realtime live preview placeholder"
                                              IsChecked="{Binding Settings.Audio.EnableLivePreview}" />
                                    <CheckBox Margin="0,8,0,0"
                                              Content="Restore clipboard after paste"
                                              IsChecked="{Binding Settings.Paste.RestoreClipboardAfterPaste}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    Background="{StaticResource PanelBrush}"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Logging" />
                                    <CheckBox Margin="0,16,0,0"
                                              Content="Enable activity log"
                                              IsChecked="{Binding Settings.Logging.EnableLogging}" />
                                    <CheckBox Margin="0,8,0,0"
                                              Content="Write transcript history"
                                              IsChecked="{Binding Settings.Logging.WriteTranscriptHistory}" />
                                    <TextBlock Margin="0,16,0,0"
                                               Text="{Binding PersistenceSummary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    Background="{StaticResource PanelBrush}"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Model Tools" />
                                    <Button Margin="0,16,0,0"
                                            Background="{StaticResource AccentBrush}"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            Command="{Binding DownloadModelCommand}"
                                            Content="Download Selected Model"
                                            Foreground="White" />
                                    <Button Margin="0,12,0,0"
                                            Command="{Binding SaveSettingsCommand}"
                                            Content="Save Settings" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
